# ============================================================
# BOW IA STUDIO — .env.example
# Copiar para .env.local e preencher com valores reais.
# NUNCA commitar .env.local — confirmar que está no .gitignore.
# ============================================================

# ── Supabase (projeto "studiobowia" (renomear para refletir BOW Creator quando possível), ref oqfyuigdhdpnvlprqdvj) ──
NEXT_PUBLIC_SUPABASE_URL=https://oqfyuigdhdpnvlprqdvj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role: segredo de root — nunca expor no client, nunca commitar.
# Girar (regenerar) se já foi exposta em algum lugar inseguro.
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n (automacoes.bow360.cloud) ──
N8N_WEBHOOK_BASE_URL=https://automacoes.bow360.cloud/webhook
N8N_API_KEY=

# ── fal.ai (gerenciado — fallback quando usuário não tem BYOK) ──
FAL_API_KEY=

# ── Provedores de IA para o Gerador de Prompt (gerenciados) ──
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Criptografia de chaves BYOK (api_connections.encrypted_key) ──
# Definir estratégia na Fase 3 — Supabase Vault (pgsodium) ou equivalente
ENCRYPTION_KEY=

# ── Gateway de pagamento: Asaas (decidido, ver DECISIONS.md #004) ──
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=        # String secreta — cadastrar em Asaas → Configurações → Integrações → Webhook
ASAAS_API_URL=https://sandbox.asaas.com/api/v3   # Trocar para https://api.asaas.com/v3 em produção
# Stripe não está em uso na v1 — manter comentado, reativar só se expandir para fora do Brasil
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ── Gmail (notificação opcional de geração concluída) ──
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── App ──
NEXT_PUBLIC_APP_URL=https://bowcreator.com.br
NODE_ENV=development
